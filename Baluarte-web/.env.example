# ==========================================
# Baluarte Web / Expo - Environment Template
# Copy this file to .env before running web
# ==========================================

EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_USE_MOCK_CATEGORIES=false

# Keep aligned with APP_AUTH_ADMIN_EMAILS in backend
EXPO_PUBLIC_ADMIN_EMAILS=admin@baluarte.com

# Public client keys only (never place secret keys in web env)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Payment
EXPO_PUBLIC_PAYMENT_PROVIDER=mock
EXPO_PUBLIC_PAYMENT_CARD_TOKEN_MODE=mock
EXPO_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Shipping
EXPO_PUBLIC_SHIPPING_PROVIDER=melhor_envio
