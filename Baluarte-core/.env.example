# ==========================================
# Baluarte Core - Environment Template
# Copy this file to .env before running core
# ==========================================

DB_URL=jdbc:postgresql://localhost:5432/baluarte
DB_USERNAME=postgres
DB_PASSWORD=postgres
SPRING_PROFILES_ACTIVE=dev

# Supabase example for hosted Postgres
# DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<supabase-database-password>

# Admin authorization and Clerk
APP_AUTH_ADMIN_EMAILS=admin@baluarte.com
APP_AUTH_CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
APP_AUTH_CLERK_JWKS_URI=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
APP_AUTH_CLERK_SECRET_KEY=
APP_AUTH_CLERK_WEBHOOK_SECRET=

# Payment provider
APP_PAYMENT_PROVIDER=mock

# Mercado Pago
APP_PAYMENT_MERCADOPAGO_BASE_URL=https://api.mercadopago.com
APP_PAYMENT_MERCADOPAGO_ACCESS_TOKEN=
APP_PAYMENT_MERCADOPAGO_PUBLIC_KEY=
APP_PAYMENT_MERCADOPAGO_WEBHOOK_SECRET=

# Shipping provider and labels
APP_SHIPPING_PROVIDER=mock
APP_SHIPPING_ORIGIN_CEP=01153000
APP_SHIPPING_PACKAGE_PRODUCT_WEIGHT_KG=0.3
APP_SHIPPING_PACKAGE_PRODUCT_HEIGHT_CM=4
APP_SHIPPING_PACKAGE_PRODUCT_WIDTH_CM=25
APP_SHIPPING_PACKAGE_PRODUCT_LENGTH_CM=35

# SuperFrete
APP_SHIPPING_SUPERFRETE_BASE_URL=https://sandbox.superfrete.com
APP_SHIPPING_SUPERFRETE_TOKEN=
APP_SHIPPING_SUPERFRETE_SERVICES=1,2,17
APP_SHIPPING_SUPERFRETE_USER_AGENT=Baluarte/1.0 (contato@baluarte.com)
APP_SHIPPING_WEBHOOK_SECRET=
