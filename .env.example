# ==========================================
# Baluarte - Environment Template (Docker)
# Copy this file to .env and fill real values
# ==========================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=baluarte
DB_URL=jdbc:postgresql://db:5432/baluarte
DB_USERNAME=postgres
DB_PASSWORD=postgres
SPRING_PROFILES_ACTIVE=prod

# Admin authorization and Clerk (backend)
APP_AUTH_ADMIN_EMAILS=admin@baluarte.com
APP_AUTH_ADMIN_CLERK_USER_IDS=
APP_AUTH_CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
APP_AUTH_CLERK_JWKS_URI=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
APP_AUTH_DEV_BYPASS_ENABLED=false
APP_AUTH_DEV_BYPASS_KEY=
APP_AUTH_CLERK_SECRET_KEY=
APP_AUTH_CLERK_WEBHOOK_SECRET=

# Mercado Pago (backend)
APP_PAYMENT_MERCADOPAGO_ACCESS_TOKEN=
APP_PAYMENT_MERCADOPAGO_PUBLIC_KEY=
APP_PAYMENT_MERCADOPAGO_WEBHOOK_SECRET=

# Shipping / label generation provider (backend)
APP_SHIPPING_PROVIDER=melhor_envio
APP_SHIPPING_BASE_URL=https://sandbox.melhorenvio.com.br
APP_SHIPPING_API_TOKEN=
APP_SHIPPING_WEBHOOK_SECRET=

# Web / Expo public runtime vars
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_USE_MOCK_CATEGORIES=false
EXPO_PUBLIC_ADMIN_EMAILS=admin@baluarte.com
EXPO_PUBLIC_ADMIN_BYPASS_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
EXPO_PUBLIC_SHIPPING_PROVIDER=melhor_envio
