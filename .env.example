# ==========================================
# Baluarte - Environment Template
# Copy this file to .env and fill real values.
# Backend (Spring Boot / Docker) vars use APP_* prefix.
# Frontend (Next.js / Vercel) public vars use NEXT_PUBLIC_* prefix.
# ==========================================

# ---------- Database ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=baluarte
DB_URL=jdbc:postgresql://db:5432/baluarte
DB_USERNAME=postgres
DB_PASSWORD=postgres
SPRING_PROFILES_ACTIVE=prod
# Produção: pool aumentado para 10 (ver auditoria #6)
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=0
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=10000

# ---------- Auth (FusionAuth) — backend ----------
APP_FUSIONAUTH_ISSUER=auth.stackway.xyz
APP_FUSIONAUTH_JWKS_URI=https://auth.stackway.xyz/.well-known/jwks.json
APP_FUSIONAUTH_API_KEY=
APP_FUSIONAUTH_APPLICATION_ID=
APP_AUTH_ADMIN_EMAILS=admin@baluarte.com
APP_AUTH_ADMIN_USER_IDS=
APP_AUTH_DEV_BYPASS_ENABLED=false
APP_AUTH_DEV_BYPASS_KEY=
# Quando implementar o CMS (ver docs/cms-system-study.md):
# APP_AUTH_SUPER_ADMIN_EMAILS=

# ---------- Auth (FusionAuth) — frontend (Vercel) ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
FUSIONAUTH_ISSUER=https://auth.stackway.xyz
FUSIONAUTH_CLIENT_ID=
FUSIONAUTH_CLIENT_SECRET=
FUSIONAUTH_API_KEY=

# ---------- Proxy de identidade (frontend -> backend) ----------
# Em migração para JWT direto (auditoria #7). Hoje o proxy assina X-User-Id/X-User-Email.
PROXY_SECRET=
BACKEND_INTERNAL_URL=http://localhost:8080

# ---------- Mercado Pago (backend) ----------
APP_PAYMENT_PROVIDER=mercadopago
APP_PAYMENT_MERCADOPAGO_ACCESS_TOKEN=
APP_PAYMENT_MERCADOPAGO_PUBLIC_KEY=
APP_PAYMENT_MERCADOPAGO_WEBHOOK_SECRET=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# ---------- Frete (SuperFrete) — backend ----------
APP_SHIPPING_PROVIDER=superfrete
APP_SHIPPING_SUPERFRETE_BASE_URL=https://sandbox.superfrete.com
APP_SHIPPING_SUPERFRETE_TOKEN=
APP_SHIPPING_SUPERFRETE_WEBHOOK_SECRET=
APP_SHIPPING_SUPERFRETE_SERVICES=1,2,17
APP_SHIPPING_SUPERFRETE_USER_AGENT=Baluarte/1.0 (contato@baluarte.com)
# Produção:
# APP_SHIPPING_SUPERFRETE_BASE_URL=https://api.superfrete.com
# APP_SHIPPING_SUPERFRETE_TOKEN=<token-producao>

# ---------- Armazenamento S3 (R2) ----------
APP_STORAGE_S3_ENDPOINT=
APP_STORAGE_S3_REGION=auto
APP_STORAGE_S3_BUCKET=
APP_STORAGE_S3_ACCESS_KEY_ID=
APP_STORAGE_S3_SECRET_ACCESS_KEY=

# ---------- PII / LGPD (auditoria #8) ----------
# AES-256-GCM. Base64(32 bytes). Obrigatórias em prod para criptografar CPF/email/endereço.
APP_PII_ENCRYPTION_KEY=
APP_PII_HMAC_KEY=

# ---------- CloudAMQP / LavinMQ (fila async p/ webhooks e pós-checkout) ----------
# Formato: amqps://user:pass@host/vhost - deixar vazio desativa o AMQP.
APP_AMQP_URL=
APP_AMQP_PREFETCH=5

# ---------- Email (Stalwart Mail SMTP) ----------
APP_EMAIL_FROM=Baluarte <contato@dombaluarte.com.br>
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_TRUST=mail.stackway.xyz

# ---------- Axiom Observability ----------
# Backend (Spring Boot / VPS) — OTLP via Micrometer (native-image safe; o OTel Java Agent NÃO funciona)
# Gerar token em: cloud.axiom.co → Settings → API Tokens → New Ingest Token
AXIOM_INGEST_TOKEN=
AXIOM_DATASET=baluarte-prod
DEPLOYMENT_ENVIRONMENT=production
TRACING_SAMPLING_PROBABILITY=1.0
OTLP_METRICS_ENABLED=true
OTLP_METRICS_URL=https://api.axiom.co/v1/metrics
OTLP_TRACES_ENDPOINT=https://api.axiom.co/v1/traces
# Frontend (Next.js) — logs e web vitals via next-axiom (standalone, SEM integração Vercel)
NEXT_PUBLIC_AXIOM_INGEST_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=baluarte-prod

# ---------- Frontend (Next.js) ----------
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080

# ---------- Job de PDF das entregas em estações (ver docs/station-delivery-report-job.md) ----------
APP_STATION_DELIVERY_REPORT_ENABLED=true
APP_STATION_DELIVERY_REPORT_RUN_TIME=18:00
APP_STATION_DELIVERY_REPORT_CHECK_DELAY_MS=60000
APP_STATION_DELIVERY_REPORT_WEBHOOK_URL=
APP_STATION_DELIVERY_REPORT_WEBHOOK_SECRET=
