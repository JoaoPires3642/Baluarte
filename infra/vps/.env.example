# Banco
POSTGRES_USER=baluarte
POSTGRES_PASSWORD=<senha-forte-32-chars>

# Spring Boot
SPRING_PROFILES_ACTIVE=prod
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
DB_URL=jdbc:postgresql://db:5432/baluarte
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# CORS
APP_CORS_ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# Clerk
APP_AUTH_CLERK_ISSUER=https://<seu-clerk>.clerk.accounts.dev
APP_AUTH_CLERK_JWKS_URI=https://<seu-clerk>.clerk.accounts.dev/.well-known/jwks.json
APP_AUTH_ADMIN_EMAILS=<emails-admin>
APP_AUTH_CLERK_SECRET_KEY=sk_***
APP_AUTH_CLERK_WEBHOOK_SECRET=whsec_***

# Mercado Pago
APP_PAYMENT_MERCADOPAGO_ACCESS_TOKEN=APP_USR-***
APP_PAYMENT_MERCADOPAGO_PUBLIC_KEY=APP_USR-***
APP_PAYMENT_MERCADOPAGO_WEBHOOK_SECRET=***

# SuperFrete
APP_SHIPPING_PROVIDER=superfrete
APP_SHIPPING_SUPERFRETE_BASE_URL=https://api.superfrete.com
APP_SHIPPING_SUPERFRETE_TOKEN=***
APP_SHIPPING_SUPERFRETE_SERVICES=1,2,17
APP_SHIPPING_SUPERFRETE_USER_AGENT=Baluarte/1.0 (contato@seudominio.com)

# Uploads
APP_MEDIA_UPLOAD_DIR=/var/www/uploads
